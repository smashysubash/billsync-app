# BillSync — Environment Variables
# Copy this file to .env and fill in your values.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/billsync?retryWrites=true&w=majority

# Zoho Books API credentials
# https://www.zoho.com/books/api/v3/oauth/#overview
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=

# Upload directory (inside the container)
UPLOAD_DIR=uploads
