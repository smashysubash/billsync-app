# BillSync — Environment Variables
# Copy this file to .env and fill in your values.

# MongoDB connection string (Atlas or Local)
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/billsync?retryWrites=true&w=majority

# Zoho Books API credentials
# Note: These are OPTIONAL if you use the "Connect Zoho Books" flow in the app UI.
# Credentials set here act as a fallback and will be overriden by UI-set values.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=

# Frontend API Configuration
# Points to the backend server (e.g., http://localhost:8001 in development)
VITE_API_URL=http://localhost:8001

# System Settings
UPLOAD_DIR=uploads
